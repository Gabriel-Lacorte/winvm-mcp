# Normalize line endings: LF in the repo, native on checkout.
* text=auto eol=lf

# Windows-side scripts keep CRLF (PowerShell is happier that way).
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary artifacts — never diff/merge.
*.png   binary
*.zip   binary
*.dmp   binary
*.mdmp  binary
